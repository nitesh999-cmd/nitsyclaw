{
  "name": "nitsyclaw",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "pnpm -r typecheck",
    "release:check": "pnpm lint && pnpm -r typecheck && pnpm build && pnpm test:coverage && pnpm test:e2e && pnpm run security:deep",
    "release:preflight": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/preflight.ps1",
    "release:vercel-build": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/vercel-build.ps1",
    "release:live-smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/live-smoke.ps1",
    "release:post-deploy-proof": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/post-deploy-proof.ps1",
    "release:wait-railway": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/railway-wait-for-commit.ps1",
    "release:whatsapp-full": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/whatsapp-full-release.ps1",
    "ci:powershell": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-powershell-syntax.ps1",
    "ci:whatsapp-replies": "pnpm run whatsapp:reply-shape",
    "ci:whatsapp-snapshots": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/whatsapp-reply-snapshots-check.ps1",
    "ci:provider-readiness": "vitest run apps/dashboard/src/lib/provider-setup-readiness.test.ts apps/bot/src/whatsapp-provider-readiness.test.ts health-page.test.ts integrations-page.test.ts integrations-health-route.test.ts setup-page.test.ts",
    "ci:tenant-isolation": "vitest run packages/shared/test/tenant-boundaries.test.ts packages/shared/src/customer-instance.test.ts packages/shared/src/db/repo-tenant-guard.test.ts dashboard-customer-data-routes.test.ts tenant-migration-plan.test.ts tenant-access-inventory.test.ts tenant-owner-hash-migration-draft.test.ts",
    "provider:health": "pnpm exec tsx scripts/provider-health.ts",
    "railway:login": "pnpm dlx @railway/cli login --browserless",
    "railway:preflight": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/railway-preflight.ps1",
    "railway:diagnose": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/railway-diagnose.ps1",
    "railway:qr-open": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/railway-qr-open.ps1",
    "railway:qr-close": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/railway-qr-close.ps1",
    "railway:whatsapp-recover": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/railway-whatsapp-recover.ps1",
    "railway:whatsapp-survival": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/railway-whatsapp-survival-proof.ps1",
    "whatsapp:proof-local": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/whatsapp-proof-local.ps1",
    "whatsapp:receipt-guard": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/whatsapp-receipt-guard.ps1",
    "whatsapp:reply-shape": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/whatsapp-reply-shape.ps1",
    "whatsapp:reply-shape-report": "pnpm exec tsx scripts/whatsapp-reply-shape-report.ts",
    "whatsapp:reply-snapshots": "pnpm exec tsx scripts/whatsapp-reply-shape-report.ts --write-snapshots",
    "whatsapp:release-gate": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/whatsapp-release-gate.ps1",
    "whatsapp:prod-smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/whatsapp-production-smoke.ps1",
    "railway:whatsapp-ready": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/railway-whatsapp-ready.ps1",
    "audit:doctor": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/audit-doctor.ps1",
    "security:semgrep": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/semgrep-scan.ps1",
    "security:audit": "pnpm audit --audit-level=moderate",
    "security:snyk": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/snyk-scan.ps1",
    "security:zap": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/zap-baseline.ps1",
    "security:deep": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/security-deep.ps1",
    "operator:next": "pnpm exec tsx scripts/operator-runner.ts --dry-run",
    "operator:doctor": "pnpm exec tsx scripts/operator-queue-doctor.ts",
    "operator:claim": "pnpm exec tsx scripts/operator-runner.ts --claim",
    "operator:run": "pnpm exec tsx scripts/operator-runner.ts --run",
    "operator:complete": "pnpm exec tsx scripts/operator-complete.ts",
    "operator:reject-unsafe": "pnpm exec tsx scripts/operator-runner.ts --reject-unsafe",
    "customer:check": "pnpm exec tsx scripts/customer-instance-check.ts",
    "tenant:check": "pnpm exec tsx scripts/tenant-boundary-check.ts",
    "tenant:access-inventory": "pnpm exec tsx scripts/tenant-access-inventory.ts",
    "tenant:migration-plan": "pnpm exec tsx scripts/tenant-migration-plan-check.ts",
    "watchdog:heartbeat": "pnpm exec tsx scripts/watchdog-heartbeat.ts",
    "db:generate": "pnpm --filter @nitsyclaw/shared db:generate",
    "db:migrate": "pnpm --filter @nitsyclaw/shared db:migrate",
    "db:studio": "pnpm --filter @nitsyclaw/shared db:studio",
    "bot": "pnpm --filter @nitsyclaw/bot dev",
    "bot:loop": "pnpm --filter @nitsyclaw/bot start",
    "dashboard": "pnpm --filter @nitsyclaw/dashboard dev",
    "google:auth": "pnpm --filter @nitsyclaw/bot google:auth",
    "bot:doctor": "pnpm exec tsx scripts/bot-startup-doctor.ts",
    "whatsapp:smoke": "vitest run apps/bot/test/router.integration.test.ts apps/bot/src/personal-command-shortcuts.test.ts apps/bot/src/wwebjs-client.test.ts apps/bot/src/whatsapp-loop-breaker.test.ts",
    "clean": "pnpm -r exec rm -rf node_modules dist .next .turbo"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "8.59.3",
    "@typescript-eslint/parser": "8.59.3",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.12.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.1",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=22.3.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "drizzle-orm@<0.45.2": ">=0.45.2",
      "esbuild@<=0.24.2": "0.25.0",
      "postcss@<8.5.10": ">=8.5.10",
      "vite@<=6.4.1": "6.4.2",
      "ip-address": "10.1.1",
      "basic-ftp@<=5.3.1": "5.3.1",
      "brace-expansion@>=5.0.0 <5.0.6": "5.0.6",
      "ws@>=8.0.0 <8.20.1": "8.20.1",
      "qs@>=6.11.1 <=6.15.1": "6.15.2"
    }
  }
}
