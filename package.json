{
  "name": "nitsyclaw",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "pnpm -r typecheck",
    "release:check": "pnpm lint && pnpm -r typecheck && pnpm build && pnpm test:coverage && pnpm test:e2e && pnpm audit --audit-level=moderate",
    "release:preflight": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/preflight.ps1",
    "operator:next": "pnpm exec tsx scripts/operator-runner.ts --dry-run",
    "operator:claim": "pnpm exec tsx scripts/operator-runner.ts --claim",
    "operator:reject-unsafe": "pnpm exec tsx scripts/operator-runner.ts --reject-unsafe",
    "db:generate": "pnpm --filter @nitsyclaw/shared db:generate",
    "db:migrate": "pnpm --filter @nitsyclaw/shared db:migrate",
    "db:studio": "pnpm --filter @nitsyclaw/shared db:studio",
    "bot": "pnpm --filter @nitsyclaw/bot dev",
    "bot:loop": "pnpm --filter @nitsyclaw/bot start:loop",
    "dashboard": "pnpm --filter @nitsyclaw/dashboard dev",
    "google:auth": "pnpm --filter @nitsyclaw/bot google:auth",
    "clean": "pnpm -r exec rm -rf node_modules dist .next .turbo"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "8.59.1",
    "@typescript-eslint/parser": "8.59.1",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.12.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.1",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
