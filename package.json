{
  "name": "nitsyclaw",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "pnpm -r typecheck",
    "release:check": "pnpm lint && pnpm -r typecheck && pnpm build && pnpm test:coverage && pnpm test:e2e && pnpm run security:deep",
    "release:preflight": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/preflight.ps1",
    "release:vercel-build": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/vercel-build.ps1",
    "release:live-smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/live-smoke.ps1",
    "audit:doctor": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/audit-doctor.ps1",
    "security:semgrep": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/semgrep-scan.ps1",
    "security:audit": "pnpm audit --audit-level=moderate",
    "security:snyk": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/snyk-scan.ps1",
    "security:zap": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/zap-baseline.ps1",
    "security:deep": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/security-deep.ps1",
    "operator:next": "pnpm exec tsx scripts/operator-runner.ts --dry-run",
    "operator:claim": "pnpm exec tsx scripts/operator-runner.ts --claim",
    "operator:reject-unsafe": "pnpm exec tsx scripts/operator-runner.ts --reject-unsafe",
    "watchdog:heartbeat": "pnpm exec tsx scripts/watchdog-heartbeat.ts",
    "db:generate": "pnpm --filter @nitsyclaw/shared db:generate",
    "db:migrate": "pnpm --filter @nitsyclaw/shared db:migrate",
    "db:studio": "pnpm --filter @nitsyclaw/shared db:studio",
    "bot": "pnpm --filter @nitsyclaw/bot dev",
    "bot:loop": "pnpm --filter @nitsyclaw/bot start",
    "dashboard": "pnpm --filter @nitsyclaw/dashboard dev",
    "google:auth": "pnpm --filter @nitsyclaw/bot google:auth",
    "clean": "pnpm -r exec rm -rf node_modules dist .next .turbo"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "8.59.1",
    "@typescript-eslint/parser": "8.59.1",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.12.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.1",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=22.3.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "drizzle-orm@<0.45.2": ">=0.45.2",
      "esbuild@<=0.24.2": "0.25.0",
      "postcss@<8.5.10": ">=8.5.10",
      "vite@<=6.4.1": "6.4.2",
      "ip-address": "10.1.1",
      "basic-ftp@<=5.3.0": "5.3.1"
    }
  }
}
