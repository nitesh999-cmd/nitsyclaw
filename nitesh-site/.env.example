# Environment variables for the Nitesh Basudkar site.
# Copy to .env.local for local dev, and set the same in Vercel → Project → Settings → Environment Variables.
# Nothing here is required for the site to run — these are optional enhancements.

# The canonical public URL (used for SEO canonical tags, sitemap, and Open Graph).
# Set this to your final domain once deployed.
NEXT_PUBLIC_SITE_URL=https://niteshbasudkar.com

# OPTIONAL — Web3Forms access key to capture leads to your inbox as a backend
# fallback (free tier at https://web3forms.com). If unset, the contact form
# falls back to the WhatsApp/email hand-off, which works with zero config.
# NEXT_PUBLIC_WEB3FORMS_KEY=
