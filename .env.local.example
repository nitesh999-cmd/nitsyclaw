# NitsyClaw .env.local — copy to .env.local and fill real values.
# .env.local is gitignored.

NODE_ENV="development"
TIMEZONE="Asia/Kolkata"

GITHUB_PAT="ghp_xxx"

ANTHROPIC_API_KEY="sk-ant-xxx"
ANTHROPIC_MODEL="claude-sonnet-4-6"

OPENAI_API_KEY="sk-xxx"
TRANSCRIPTION_MODEL="whisper-1"

DATABASE_URL="postgresql://postgres.<ref>:<pass>@aws-0-<region>.pooler.supabase.com:6543/postgres"
DATABASE_URL_DIRECT="postgresql://postgres:<pass>@db.<ref>.supabase.co:5432/postgres"

WHATSAPP_SESSION_DIR=".wa-session"
WHATSAPP_OWNER_NUMBER="91XXXXXXXXXX"

WHATSAPP_CLOUD_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_VERIFY_TOKEN=""

ENCRYPTION_KEY=""

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/integrations/google/callback"

DAILY_LLM_BUDGET_USD="5"

ENABLE_HEARTBEAT="true"
ENABLE_WEB_RESEARCH="true"
QUIET_HOURS_START="22:00"
QUIET_HOURS_END="07:00"
