# NitsyClaw .env.local — copy to .env.local and fill real values.
# .env.local is gitignored.

NODE_ENV="development"
TIMEZONE="Australia/Melbourne"
HOME_CITY="Melbourne"
HOME_REGION="Victoria"
HOME_COUNTRY="Australia"
CURRENT_CITY=""
CURRENT_REGION=""
CURRENT_COUNTRY=""

GITHUB_PAT="replace-with-github-token"

ANTHROPIC_API_KEY="replace-with-anthropic-api-key"
ANTHROPIC_MODEL="claude-sonnet-4-6"

OPENAI_API_KEY="replace-with-openai-api-key"
TRANSCRIPTION_MODEL="whisper-1"

# Optional: real web search via Serper (https://serper.dev — 2500 free queries/month).
# Without this, the LLM still uses Anthropic server-side web_search in the agent tool loop.
SERPER_API_KEY=""

DATABASE_URL="postgresql://postgres.<ref>:<pass>@aws-0-<region>.pooler.supabase.com:6543/postgres"
DATABASE_URL_DIRECT="postgresql://postgres:<pass>@db.<ref>.supabase.co:5432/postgres"

# ".wa-session" is resolved outside the repo under NITSYCLAW_SECRET_ROOT.
# Use an absolute path only when you have mounted persistent storage there.
NITSYCLAW_SECRET_ROOT=""
WHATSAPP_SESSION_DIR=".wa-session"
WHATSAPP_OWNER_NUMBER="91XXXXXXXXXX"
# Keeps WhatsApp Web presence pushed to "unavailable" while the bot is connected.
# Set to 0 to disable. Default when blank/unset: 60000.
NITSYCLAW_PRESENCE_UNAVAILABLE_INTERVAL_MS=""

WHATSAPP_CLOUD_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_VERIFY_TOKEN=""

# Required for encrypted storage and export/delete proofs.
# 32 random bytes: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Production key must be set separately in Vercel. Generate a fresh one for local dev.
ENCRYPTION_KEY=""

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# Dev auth bypass: set to "1" in local dev when no DASHBOARD_PASSWORD is configured.
# MUST NOT be set on Vercel (production or preview). Verify: vercel env ls production.
NITSYCLAW_DEV_AUTH_BYPASS=""

NITSYCLAW_DASHBOARD_USER="nitesh"
NITSYCLAW_DASHBOARD_PASSWORD=""

# Local development diagnostics only. /debug is disabled in production even if this is set.
NITSYCLAW_ENABLE_DEBUG=""

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/integrations/google/callback"

SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""
SPOTIFY_REDIRECT_URI="http://localhost:3000/api/integrations/spotify/callback"

DAILY_LLM_BUDGET_USD="5"

ENABLE_HEARTBEAT="true"
ENABLE_WEB_RESEARCH="true"
QUIET_HOURS_START="22:00"
QUIET_HOURS_END="07:00"

# Notification email — sent via Microsoft Graph sendMail when NOTIFY_EMAIL is set and M365 token exists.
NOTIFY_EMAIL=""

# Dashboard URL used by build-agent notifications.
DASHBOARD_URL="https://nitsyclaw.vercel.app"

# Cron schedule overrides (node-cron syntax). Defaults shown.
MORNING_BRIEF_CRON="0 7 * * *"
BUILD_AGENT_CRON="0 12 * * *"
MEMORY_PRUNER_CRON="0 3 * * *"

# Days to retain messages before pruning (default: 90).
PRUNE_MESSAGES_DAYS="90"

# M365 / Microsoft Graph auth timeout override (ms, 0–5000).
NITSYCLAW_AUTH_ATTEMPT_TIMEOUT_MS=""
